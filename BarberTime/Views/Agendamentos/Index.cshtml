@model IEnumerable<BarberTime.Models.Agendamento>
@using System.Linq

@{
    ViewData["Title"] = "Agendamentos";
}

<div class="agendamento-page">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="page-title mb-1">Agendamentos </h1>
            <p class="text-muted mb-0">Gerencie os horários da barbearia.</p>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <a asp-action="Create" class="btn btn-dark rounded-pill px-4 shadow-sm">
                + Novo Agendamento
            </a>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            var badgeClass = item.Status switch
            {
                "Confirmado" => "status-confirmado",
                "Em Andamento" => "status-andamento",
                "Concluido" => "status-concluido",
                _ => "status-default"
            };

            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <div class="card agendamento-card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="cliente-nome mb-1">@item.NomeCliente</h5>
                                <small class="text-muted d-block">@item.Telefone</small>
                                <small class="text-muted d-block">@(item.Servico?.Nome ?? "Sem serviço")</small>
                            </div>

                            <span class="status-badge @badgeClass">
                                @item.Status
                            </span>
                        </div>

                        <div class="info-item">
                            <small class="info-label">Data e Hora</small>
                            <div class="info-value"> @item.DataHora.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>

                        <div class="info-item">
                            <small class="info-label">Serviço</small>
                            <div class="info-value"> @item.Servico?.Nome</div>
                        </div>

                        <div class="info-item">
                            <small class="info-label">Duração</small>
                            <div class="info-value"> @(item.Servico?.DuracaoEmMinutos ?? 0) min</div>
                        </div>

                        <div class="info-item">
                            <small class="info-label">Preço</small>
                            <div class="info-value"> R$ @(item.Servico?.Preco.ToString("N2") ?? "0,00")</div>
                        </div>

                        <div class="info-item">
                            <small class="info-label">Observações</small>
                            <div class="observacao-box">
                                @(string.IsNullOrWhiteSpace(item.Observacoes) ? "Sem observações" : item.Observacoes)
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm w-100 rounded-pill">
                                Editar
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm w-100 rounded-pill">
                                Excluir
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state text-center py-5">
            <h4>Nenhum agendamento encontrado</h4>
            <p class="text-muted">Comece criando o primeiro agendamento.</p>
            <a asp-action="Create" class="btn btn-dark rounded-pill px-4">
                + Novo Agendamento
            </a>
        </div>
    }
</div>