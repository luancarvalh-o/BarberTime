@model BarberTime.Models.Servico

@{
    ViewData["Title"] = "Editar Serviço";
}

<div class="form-page">
    <div class="form-card shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="page-title mb-1">Editar Serviço </h1>
                <p class="text-muted mb-0">Atualize os dados do serviço.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                Voltar
            </a>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nome" class="form-label custom-label"></label>
                    <input asp-for="Nome" class="form-control custom-input" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Preco" class="form-label custom-label"></label>
                    <input asp-for="Preco" type="number" step="0.01" class="form-control custom-input" />
                    <span asp-validation-for="Preco" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="DuracaoEmMinutos" class="form-label custom-label"></label>
                    <input asp-for="DuracaoEmMinutos" type="number" class="form-control custom-input" />
                    <span asp-validation-for="DuracaoEmMinutos" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <div class="form-check mt-4 pt-2">
                        <input asp-for="Ativo" class="form-check-input" />
                        <label asp-for="Ativo" class="form-check-label custom-label"></label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary rounded-pill px-4">
                    Salvar Alterações
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}